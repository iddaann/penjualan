# ============================================================
# TOKO APP - Environment Variables
# ============================================================
# Copy file ini menjadi .env dan isi dengan nilai dari Supabase project Anda
# Jangan commit file .env ke git!

# Supabase Project URL (dari Settings > API di dashboard Supabase)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (dari Settings > API di dashboard Supabase)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
